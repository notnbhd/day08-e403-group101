# =============================================================================
# RAG Pipeline v2 — Environment Variables
# Copy file này thành .env rồi điền key thật:  cp .env.example .env
# =============================================================================

# --- OpenRouter ---------------------------------------------------------------
# 1 key duy nhất dùng cho: embeddings (Task 4), rerank (Task 7), LLM (Task 10).
# Lấy key tại: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Models (đổi tự do, không cần sửa code) -----------------------------------
LLM_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536
RERANK_MODEL=cohere/rerank-v3.5

# --- Weaviate Cloud (Task 4, 5, 6, 9) -----------------------------------------
# Tạo cluster miễn phí tại: https://console.weaviate.cloud
WEAVIATE_URL=https://xxx.weaviate.network
WEAVIATE_API_KEY=xxx
WEAVIATE_COLLECTION=DrugLawDocs

# --- PageIndex (Task 8 - vectorless RAG) --------------------------------------
# Đăng ký + lấy key tại: https://pageindex.ai
PAGEINDEX_API_KEY=pi_xxx
